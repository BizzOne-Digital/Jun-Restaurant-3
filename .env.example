# MongoDB Connection
# Get your connection string from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mascot-chinese?retryWrites=true&w=majority

# Session Secret (must be at least 32 characters, use a random string)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-minimum-32-characters-long

# App URL (used for redirects and metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# Seed API Key (used to protect the /api/seed endpoint in production)
SEED_API_KEY=your-seed-api-key-here

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Mailgun — get these from https://app.mailgun.com
MAILGUN_API_KEY=your-mailgun-private-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=orders@merchantorders.io
MAILGUN_ORDERS_EMAIL=orders@merchantorders.io

# Set to "false" to skip sending the customer order confirmation email
ORDER_SEND_CUSTOMER_CONFIRMATION=true

# Restaurant logo URL (Cloudinary or any public HTTPS image URL)
# Used in HTML email headers. If not set, emails are sent without a logo.
RESTAURANT_LOGO_URL=https://res.cloudinary.com/your-cloud/image/upload/v1/your-logo.png
